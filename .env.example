# Local demo defaults
EPHEMEROS_CONTEXT_DIR=.bob_restricted_context
EPHEMEROS_CONTEXT_SOURCE=secure-enclave
EPHEMEROS_FILTER_PROVIDER=local
EPHEMEROS_MCP_MOCK=true
EPHEMEROS_MOCK_CONTEXT=true
EPHEMEROS_HOST=127.0.0.1
EPHEMEROS_PORT=3000

# Tailscale/local reachability demo
EPHEMEROS_VPN_TEST_URL=http://100.82.136.35:8080/ephemeros-vpn-health.txt
EPHEMEROS_VPN_TIMEOUT_MS=10000
EPHEMEROS_VPN_BIND_HOST=0.0.0.0
EPHEMEROS_VPN_TARGET_PORT=8080

# Optional watsonx.ai filter. Leave blank unless running npm.cmd run demo:watsonx.
IBM_API_KEY=<redacted>
WATSONX_PROJECT_ID=<redacted>

# Optional AWS Lambda path. Local demo does not need this.
AWS_REGION=ap-southeast-1
EPHEMEROS_LAMBDA_FUNCTION=

# Optional Express auth token. MCP demo does not need this.
EPHEMEROS_AUTH_TOKEN=
